generator client {
  provider = "prisma-client-js"
  output   = "../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VICTIM
  OFFICER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum FIRStatus {
  DRAFT
  SUBMITTED
  ACKNOWLEDGED
  UNDER_INVESTIGATION
  CHARGESHEET_FILED
  CLOSED
  REJECTED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Language {
  ENGLISH
  HINDI
  BHOJPURI
  MARATHI
  TAMIL
  TELUGU
  BENGALI
  GUJARATI
  KANNADA
  MALAYALAM
  PUNJABI
  ODIA
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum OfficerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum CrimeCategory {
  VIOLENT
  PROPERTY
  CYBERCRIME
  DOMESTIC_VIOLENCE
  FINANCIAL_FRAUD
  SEXUAL_OFFENSE
  PUBLIC_ORDER
  DRUG_OFFENSE
  OTHER
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String   @unique
  passwordHash  String
  role          Role
  gender        Gender?
  aadhaarLast4  String?
  preferredLang Language @default(ENGLISH)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  officer          Officer?
  victimFIRs       FIR[]             @relation("VictimFIRs")
  victimStatements VictimStatement[]
  smsNotifications SMSNotification[]
  voiceRecordings  VoiceRecording[]
}

model PoliceStation {
  id               String   @id @default(cuid())
  name             String
  stationCode      String   @unique
  address          String
  district         String
  state            String
  pincode          String
  latitude         Float
  longitude        Float
  phone            String
  email            String?
  jurisdictionArea String?  @db.Text
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  officers Officer[]
  firs     FIR[]
}

model Officer {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  badgeNumber        String                    @unique
  rank               String
  department         String
  stationId          String
  verificationStatus OfficerVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  verifiedByAdminId  String?
  otpSecret          String?
  otpExpiresAt       DateTime?
  cctnsId            String?
  joinedAt           DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  station PoliceStation @relation(fields: [stationId], references: [id])
  firs    FIR[]
}

model BNSSection {
  id            String        @id @default(cuid())
  sectionNumber String        @unique
  sectionTitle  String
  description   String        @db.Text
  category      CrimeCategory

  ipcEquivalent  String?
  ipcTitle       String?
  ipcDescription String? @db.Text

  minImprisonmentMonths Int?
  maxImprisonmentMonths Int?
  isLifeOrDeath         Boolean @default(false)
  minFine               Float?
  maxFine               Float?

  isBailable     Boolean @default(false)
  isCognizable   Boolean @default(true)
  isCompoundable Boolean @default(false)

  compensationNote  String? @db.Text
  victimsRightsNote String? @db.Text
  mappingReasoning  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firs                  FIR[]                 @relation("FIRSections")
  classificationResults CrimeClassification[]
  evidenceChecklists    EvidenceChecklist[]
  rightsExplainers      RightsExplainer[]
}

model VictimStatement {
  id               String    @id @default(cuid())
  userId           String
  rawText          String?   @db.Text
  voiceRecordingId String?   @unique
  language         Language  @default(ENGLISH)
  translatedText   String?   @db.Text
  incidentDate     DateTime?
  incidentTime     String?
  incidentLocation String?
  witnessDetails   String?   @db.Text
  isUsedForFIR     Boolean   @default(false)
  firId            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User                 @relation(fields: [userId], references: [id])
  voiceRecording VoiceRecording?      @relation(fields: [voiceRecordingId], references: [id])
  fir            FIR?                 @relation(fields: [firId], references: [id])
  classification CrimeClassification?
}

model CrimeClassification {
  id                  String @id @default(cuid())
  victimStatementId   String @unique
  bnsSectionId        String
  confidenceScore     Float
  alternativeSections Json?

  urgencyLevel  UrgencyLevel
  urgencyReason String?      @db.Text
  severityScore Float?

  modelVersion String?
  createdAt    DateTime @default(now())

  victimStatement VictimStatement @relation(fields: [victimStatementId], references: [id])
  bnsSection      BNSSection      @relation(fields: [bnsSectionId], references: [id])
}

model FIR {
  id                  String       @id @default(cuid())
  firNumber           String?      @unique
  acknowledgmentNo    String?      @unique
  victimId            String
  officerId           String?
  stationId           String
  status              FIRStatus    @default(DRAFT)
  urgencyLevel        UrgencyLevel @default(MEDIUM)
  isOnlineFIR         Boolean      @default(false)
  incidentDate        DateTime
  incidentTime        String?
  incidentLocation    String
  incidentDescription String       @db.Text
  aiGeneratedSummary  String?      @db.Text
  officerSignedAt     DateTime?
  chargeSheetFiledAt  DateTime?
  closedAt            DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  victim           User              @relation("VictimFIRs", fields: [victimId], references: [id])
  officer          Officer?          @relation(fields: [officerId], references: [id])
  station          PoliceStation     @relation(fields: [stationId], references: [id])
  bnsSections      BNSSection[]      @relation("FIRSections")
  victimStatements VictimStatement[]
  caseUpdates      CaseUpdate[]
  smsNotifications SMSNotification[]
  evidenceItems    EvidenceItem[]
  voiceRecordings  VoiceRecording[]
}

model CaseUpdate {
  id          String    @id @default(cuid())
  firId       String
  status      FIRStatus
  note        String?   @db.Text
  updatedById String?
  createdAt   DateTime  @default(now())

  fir FIR @relation(fields: [firId], references: [id])
}

model VoiceRecording {
  id           String    @id @default(cuid())
  userId       String
  firId        String?
  language     Language  @default(HINDI)
  fileUrl      String
  durationSecs Int?
  transcript   String?   @db.Text
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  recordedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id])
  fir             FIR?             @relation(fields: [firId], references: [id])
  victimStatement VictimStatement?
}

model EvidenceChecklist {
  id           String   @id @default(cuid())
  bnsSectionId String
  title        String
  description  String?  @db.Text
  isTemplate   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bnsSection     BNSSection      @relation(fields: [bnsSectionId], references: [id])
  checklistItems ChecklistItem[]
}

model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  label       String
  description String?  @db.Text
  isRequired  Boolean  @default(true)
  deadline    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checklist     EvidenceChecklist @relation(fields: [checklistId], references: [id])
  evidenceItems EvidenceItem[]
}

model EvidenceItem {
  id              String    @id @default(cuid())
  firId           String
  checklistItemId String?
  label           String
  fileUrl         String?
  notes           String?   @db.Text
  isCollected     Boolean   @default(false)
  collectedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fir           FIR            @relation(fields: [firId], references: [id])
  checklistItem ChecklistItem? @relation(fields: [checklistItemId], references: [id])
}

model RightsExplainer {
  id           String   @id @default(cuid())
  bnsSectionId String?
  title        String
  content      String   @db.Text
  legalBasis   String?
  language     Language @default(ENGLISH)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bnsSection BNSSection? @relation(fields: [bnsSectionId], references: [id])
}

model SMSNotification {
  id         String             @id @default(cuid())
  userId     String
  firId      String?
  phone      String
  message    String             @db.Text
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  failReason String?
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id])
  fir  FIR? @relation(fields: [firId], references: [id])
}
