{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node --watch dist/server.js",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate --schema ../prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema ../prisma/schema.prisma --url \"$DATABASE_URL\"",
    "create:admin": "npm run build && node scripts/create-admin.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/express": "^5.0.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "prisma": "^7.7.0",
    "typescript": "^6.0.2"
  }
}
