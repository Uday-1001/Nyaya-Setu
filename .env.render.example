# Render production environment template
# Backend
NODE_ENV=production
PORT=10000
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
ML_SERVICE_URL=https://nyaya-setu-ml.onrender.com
ML_SERVICE_TIMEOUT_MS=120000
APP_URL=https://nyaya-setu-frontend.onrender.com
# Supports exact origins and wildcard patterns, comma-separated
CORS_ORIGINS=https://*.onrender.com
COOKIE_SECURE=true
JWT_ACCESS_SECRET=<generate-strong-secret>
JWT_REFRESH_SECRET=<generate-strong-secret>
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Frontend (Render Static Site env vars)
VITE_API_URL=https://nyaya-setu-backend.onrender.com/api
VITE_ML_SERVICE_URL=https://nyaya-setu-ml.onrender.com
